import { NextRequest, NextResponse } from "next/server";
import { headers } from "next/headers";
import { auth } from "@/lib/auth/server";

export async function proxy(request: NextRequest) {
    const pathname = request.nextUrl.pathname;

    // We don't want to get session on the home page if it might cause DB errors when DB is down
    // or if we want users to see the landing page regardless of auth status.
    if (pathname === "/") {
        return NextResponse.next();
    }

    let session = null;
    try {
        session = await auth.api.getSession({
            headers: await headers()
        });
    } catch (error) {
        console.error("Auth session error:", error);
        // If DB is down, we still want to show the landing page at least
        if (pathname === "/") return NextResponse.next();
    }

    if (!session) {
        // Unsigned users can access /sign-in and /sign-up
        if (pathname === "/sign-in" || pathname === "/sign-up") {
            return NextResponse.next();
        }
        // Redirect unsigned users to /sign-in for any other page (like /dashboard)
        if (pathname.startsWith("/dashboard")) {
            return NextResponse.redirect(new URL("/sign-in", request.url));
        }
    }

    // If session exists and user is on sign-in/sign-up, redirect to dashboard
    if (session && ["/sign-in", "/sign-up"].includes(pathname)) {
        return NextResponse.redirect(new URL("/dashboard", request.url));
    }

    return NextResponse.next();
}

export const config = {
    matcher: [
        /*
         * Match all request paths except for the ones starting with:
         * - api (API routes)
         * - _next/static (static files)
         * - _next/image (image optimization files)
         * - favicon.ico (favicon file)
         */
        '/((?!api|_next/static|_next/image|favicon.ico).*)',
    ],
};
